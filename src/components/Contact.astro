---
import FormFooter from "./Forms/FormFooter.astro"
import Wha from "./Contacts/Wha.astro"
import NavBarFooter from "./Navigation/NavBarFooter.astro"
---

<section id="contacto" class="relative px-6 py-22 w-full h-auto min-h-150 overflow-hidden bg-[#11161B] md:h-[80vh] md:w-[95%] md:max-w-7xl md:mx-auto md:rounded-lg md:my-8 lg:h-auto lg:w-full lg:max-w-none lg:mx-0 lg:rounded-none lg:my-0 lg:px-[8vw] lg:pt-28 lg:pb-8">

    <!-- Contenedor Superior: Usamos CSS Grid en Desktop para reordenar los elementos -->
    <div class="flex flex-col lg:grid lg:grid-cols-[45%_45%] lg:justify-between lg:items-start lg:mb-20">
        
        <!-- 1. Bloque de Textos (Móvil: Arriba | Desktop: Columna Izquierda, Fila Arriba) -->
        <div class="lg:col-start-1 lg:row-start-1">
            <p class="text-sm text-[#2A5082] font-sans font-semibold leading-relaxed mb-6 lg:tracking-[0.15em] lg:uppercase lg:mb-4 lg:block">
                CONTÁCTANOS
            </p>

            <h2 class="text-3xl text-white font-serif font-bold mb-8 lg:text-6xl lg:leading-[1.1] lg:mb-8 lg:pr-6">
                Haz tu pedido
               <br> <span class="text-[#E8E8E8]/80 italic lg:mt-2 lg:inline-block">Estamos listos para atenderte</span>
            </h2>

            <p class="text-base text-[#A1A7B0] font-sans mb-8 font-normal leading-relaxed lg:text-lg lg:mb-0 lg:pr-6">
                ¿Tienes alguna duda sobre nuestros servicios de agua o maquinaria? Déjanos tus datos y nos comunicaremos contigo lo más
                pronto posible para brindarte la mejor atención en toda la región de Oaxaca.
            </p>
        </div>

        <!-- 2. Formulario (Móvil: Medio | Desktop: Columna Derecha, Abarca todo el alto) -->
        <div class="lg:col-start-2 lg:row-start-1 lg:row-span-2 w-full">
            <FormFooter/> 
        </div>

        <!-- 3. WhatsApp (Móvil: Abajo del form | Desktop: Columna Izquierda, Debajo del texto) -->
        <div class="mt-6 mb-8 lg:mt-8 lg:mb-0 lg:col-start-1 lg:row-start-2 w-full lg:pr-6">
            <Wha/>
        </div>

    </div>
    
    <!-- Sección Media: Footer Info y Navegación -->
    <div class="bg-[#11161B] w-full  mb-4 border-t border-[#7A848D]/20 py-10 gap-8 lg:flex lg:justify-between lg:items-center lg:mt-0 lg:mb-0 lg:py-12 lg:-mx-[8vw] lg:px-[8vw]">
        
        <div class="lg:w-1/3">
            <h3 class="text-lg text-white font-serif font-bold lg:text-2xl lg:mb-1">El Montecito</h3>
            <p class="text-sm text-[#A1A7B0] font-sans mb-8 font-normal leading-relaxed lg:text-base lg:mb-0">
                La mejor calidad
            </p>
        </div>

        <div class="lg:w-2/3 lg:flex lg:justify-end">
            <NavBarFooter/>
        </div>

    </div>

    <!-- Sección Inferior: Copyright -->
    <div class="flex justify-center lg:justify-start lg:border-t lg:border-[#7A848D]/20 lg:-mx-[8vw] lg:px-[8vw] lg:pt-8 lg:pb-4">
        <p class="text-xs text-[#A1A7B0] font-sans items-center font-normal leading-relaxed lg:text-sm">
            ©2026 El Montecito. Todos los derechos reservados
        </p>
    </div>

</section>