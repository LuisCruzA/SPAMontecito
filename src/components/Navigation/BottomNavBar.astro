---
import { Icon } from 'astro-icon/components';
---
<nav class="md:hidden fixed h-auto p-2 bottom-0 z-50 flex justify-center w-full bg-white shadow-md shadow-blue-300 rounded-t-2xl border-t border-blue-200">
    <div class="flex w-full max-w-7xl items-center px-4">
        
        <ul class="flex w-full justify-between items-center text-sm">

            <li> 
                <a href="#inicio" class="nav-link  flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-blue-500 transition-colors">
                    <Icon name="lucide:house" class="w-6 h-6" />
                    <span class="text-xs font-light">Inicio</span>
                </a>
            </li>

            <li> 
                <a href="#inicio" class="nav-link  flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-blue-500 transition-colors">
                    <Icon name="lucide:building-2" class="w-6 h-6" />
                    <span class="text-xs font-light">Acerca de</span>
                </a>
            </li>

            <li> 
                <a href="#servicios" class="nav-link flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-blue-500 transition-colors">
                    <Icon name="lucide:truck" class="w-6 h-6" />
                    <span class="text-xs font-light">Servicios</span>
                </a>
            </li>

            <li> 
                <a href="#ubicacion" class="nav-link flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-blue-500 transition-colors">
                    <Icon name="lucide:map-pin" class="w-6 h-6" />
                    <span class="text-xs font-light">Ubicación</span>
                </a>
            </li>

            <li> 
                <a href="#contacto" class="nav-link flex flex-col items-center justify-center gap-1 text-gray-400 hover:text-blue-500 transition-colors">
                    <Icon name="lucide:phone" class="w-6 h-6" />
                    <span class="text-xs font-light">Contacto</span>
                </a>
            </li>

        </ul>
    </div>
</nav>

<script>
  const navLinks = document.querySelectorAll('.nav-link');
  
  const sections = document.querySelectorAll('section[id]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.getAttribute('id');
        
        navLinks.forEach(link => {
          link.classList.remove('text-blue-500');
          link.classList.add('text-gray-400');
          
          if (link.getAttribute('href') === `#${id}`) {
            link.classList.remove('text-gray-400');
            link.classList.add('text-blue-500');
          }
        });
      }
    });
  }, { 
    threshold: 0.5 
  });

  sections.forEach(section => observer.observe(section));
</script>